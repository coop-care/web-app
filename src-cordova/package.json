{
  "name": "de.coopcare.app",
  "displayName": "CoopCare",
  "version": "1.0.0",
  "description": "We relieve nurses in documentation and planning by using the Omaha System and support care teams in cooperation and in strengthening their clients.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "ecosystem:cordova"
  ],
  "author": "CoopCare Project <mail@coopcare.de>",
  "license": "AGPL-3.0",
  "devDependencies": {
    "cordova-android": "^12.0.1",
    "cordova-clipboard": "^1.3.0",
    "cordova-ios": "^7.0.1",
    "cordova-plugin-advanced-http": "^3.3.1",
    "cordova-plugin-androidx-adapter": "^1.1.3",
    "cordova-plugin-apkupdater": "^4.0.1",
    "cordova-plugin-device": "^2.1.0",
    "cordova-plugin-file": "^8.0.0",
    "cordova-plugin-inappbrowser": "^5.0.0",
    "cordova-plugin-ionic-keyboard": "^2.2.0",
    "cordova-plugin-localization-strings": "^5.0.5",
    "cordova-plugin-printer": "^0.8.0",
    "cordova-plugin-secure-key-store": "github:michaelkamphausen/cordova-plugin-secure-key-store",
    "cordova-plugin-splashscreen": "^6.0.2",
    "cordova-plugin-statusbar": "^3.0.0",
    "cordova-plugin-x-socialsharing": "^6.0.4",
    "cordova-sqlite-storage": "^6.1.0",
    "es6-promise-plugin": "^4.2.2"
  },
  "cordova": {
    "platforms": [
      "android",
      "ios"
    ],
    "plugins": {
      "cordova-plugin-printer": {
        "ANDROID_SUPPORT_V4_VERSION": "28.+"
      },
      "cordova-plugin-androidx-adapter": {},
      "cordova-plugin-secure-key-store": {},
      "cordova-plugin-file": {},
      "cordova-sqlite-storage": {},
      "cordova-plugin-splashscreen": {},
      "cordova-plugin-apkupdater": {},
      "cordova-plugin-advanced-http": {
        "ANDROIDBLACKLISTSECURESOCKETPROTOCOLS": "SSLv3,TLSv1"
      },
      "cordova-plugin-inappbrowser": {},
      "cordova-plugin-x-socialsharing": {
        "PHOTO_LIBRARY_ADD_USAGE_DESCRIPTION": "This app requires photo library access to function properly.",
        "PHOTO_LIBRARY_USAGE_DESCRIPTION": "This app requires photo library access to function properly."
      },
      "cordova-clipboard": {},
      "cordova-plugin-ionic-keyboard": {},
      "cordova-plugin-device": {},
      "cordova-plugin-localization-strings": {
        "TRANSLATION_PATH": "translations/app/"
      }
    }
  }
}